{
  "tests": [
    {
      "name": "Cities short query returns empty list",
      "method": "GET",
      "path": "/?action=cities&q=М",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "exact"
    },
    {
      "name": "create_order without order_id returns 400",
      "method": "POST",
      "path": "/?action=create_order",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "order_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "order_status without uuid returns 400",
      "method": "GET",
      "path": "/?action=order_status",
      "expectedStatus": 400,
      "expectedBody": {"error": "uuid required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "get_pvz without city_code returns 400",
      "method": "GET",
      "path": "/?action=get_pvz",
      "expectedStatus": 400,
      "expectedBody": {"error": "city_code required"},
      "bodyMatcher": "partial"
    }
  ]
}