{
  "tests": [
    {
      "name": "get streams returns 200",
      "method": "GET",
      "path": "/?action=get_streams",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "get products returns 200",
      "method": "GET",
      "path": "/?action=get_products",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "get seller profile without user_id returns 400",
      "method": "GET",
      "path": "/?action=get_seller_profile",
      "expectedStatus": 400,
      "expectedBody": {"error": "user_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "get orders returns 200",
      "method": "GET",
      "path": "/?action=get_orders",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "get_seller_orders without seller_id returns 400",
      "method": "GET",
      "path": "/?action=get_seller_orders",
      "expectedStatus": 400,
      "expectedBody": {"error": "seller_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "update_seller_order_status without required fields returns 400",
      "method": "POST",
      "path": "/?action=update_seller_order_status",
      "body": {},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "unknown action returns 404",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 404,
      "expectedBody": {"error": "unknown action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "upload_image without data returns 400",
      "method": "POST",
      "path": "/?action=upload_image",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "invalid image data"},
      "bodyMatcher": "partial"
    },
    {
      "name": "add_chat with bad words returns 400",
      "method": "POST",
      "path": "/?action=add_chat",
      "body": {"stream_id": "test", "user_id": "u1", "user_name": "Test", "text": "хуй"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Сообщение содержит недопустимые слова"},
      "bodyMatcher": "partial"
    },
    {
      "name": "get_bans without stream_id returns 400",
      "method": "GET",
      "path": "/?action=get_bans",
      "expectedStatus": 400,
      "expectedBody": {"error": "stream_id required"},
      "bodyMatcher": "partial"
    }
  ]
}