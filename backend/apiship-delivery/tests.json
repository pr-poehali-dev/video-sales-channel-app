    },
    {
      "name": "Test auth with real token",
      "method": "POST",
      "path": "/?action=test_auth",
      "expectedStatus": 200,
      "expectedBody": {"ok": "boolean"},
      "bodyMatcher": "partial"
    }
  ]
}
