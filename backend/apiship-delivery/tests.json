{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Cities short query returns empty",
      "method": "GET",
      "path": "/?action=cities&q=a",
      "expectedStatus": 200,
      "expectedBody": [],
